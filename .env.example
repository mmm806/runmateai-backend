# DB 비밀번호 (PostgreSQL 컨테이너에서 사용)
DB_PASSWORD=postgres456

# JWT Secret
JWT_SECRET=여기에_실제_JWT_SECRET_입력

# Claude API Key
CLAUDE_API_KEY=여기에_실제_CLAUDE_API_KEY_입력

# CORS 허용 도메인 (배포 후 CloudFront URL 추가)
# 예: http://localhost:5173,https://xxxx.cloudfront.net
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174